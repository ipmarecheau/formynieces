{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git remote -v)",
      "Bash(php artisan specs:trace:*)",
      "Bash(php artisan route:list:*)",
      "Bash(php artisan about)",
      "Bash(./vendor/bin/pest)",
      "Bash(./vendor/bin/pest:*)",
      "Bash(npm run build)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(free -h)",
      "Bash(df -h)",
      "Bash(which:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git add --all)",
      "Bash(rm -rf:*)",
      "Bash(php artisan migrate:fresh:*)",
      "Bash(php artisan db:wipe:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(sudo:*)"
    ]
  }
}
